{
  "name": "account-service",
  "version": "0.1.0",
  "bin": {
    "account-service": "bin/account-service.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "gen:types": "openapi-typescript openapi/account.oas.yaml -o openapi/types.ts",
